{
    "dashboard": {
        "dashboards": [
            {
                "id": "default",
                "name": "Daily Overview",
                "widgets": [
                    {
                        "id": "sleep-score",
                        "type": "score",
                        "title": "Sleep",
                        "width": "col-span-4",
                        "height": "h-40",
                        "config": { "dataKey": "sleep.score", "color": "#8AB4F8" }
                    },
                    {
                        "id": "readiness-score",
                        "type": "score",
                        "title": "Readiness",
                        "width": "col-span-4",
                        "height": "h-40",
                        "config": { "dataKey": "readiness.score", "color": "#4ade80" }
                    },
                    {
                        "id": "activity-score",
                        "type": "score",
                        "title": "Activity",
                        "width": "col-span-4",
                        "height": "h-40",
                        "config": { "dataKey": "activity.score", "color": "#f87171" }
                    },
                    {
                        "id": "sleep-radar",
                        "type": "radar",
                        "title": "Sleep contributors",
                        "width": "col-span-4",
                        "height": "h-40",
                        "config": {
                            "dataKey": "sleep.contributors",
                            "color": "#8AB4F8",
                            "dataKeys": ["sleep.contributors"]
                        }
                    },
                    {
                        "id": "readiness-radar",
                        "type": "radar",
                        "title": "Readiness contributors",
                        "width": "col-span-4",
                        "height": "h-40",
                        "config": {
                            "dataKey": "readiness.contributors",
                            "color": "#4ade80",
                            "dataKeys": ["readiness.contributors"]
                        }
                    },
                    {
                        "id": "activity-radar",
                        "type": "radar",
                        "title": "Activity contributors",
                        "width": "col-span-4",
                        "height": "h-40",
                        "config": {
                            "dataKey": "activity.contributors",
                            "color": "#f87171",
                            "dataKeys": ["activity.contributors"]
                        }
                    },
                    {
                        "id": "metric-sleep",
                        "type": "metric",
                        "title": "Total sleep",
                        "width": "col-span-3",
                        "height": "h-32",
                        "config": { "dataKey": "sleep_session.total_sleep_duration", "color": "#8AB4F8" }
                    },
                    {
                        "id": "metric-hrv",
                        "type": "metric",
                        "title": "Avg HRV",
                        "width": "col-span-3",
                        "height": "h-32",
                        "config": { "dataKey": "sleep_session.average_hrv", "color": "#c084fc", "unit": "ms" }
                    },
                    {
                        "id": "metric-rhr",
                        "type": "metric",
                        "title": "Resting HR",
                        "width": "col-span-3",
                        "height": "h-32",
                        "config": { "dataKey": "sleep_session.lowest_heart_rate", "color": "#f87171", "unit": "bpm" }
                    },
                    {
                        "id": "metric-steps",
                        "type": "metric",
                        "title": "Steps",
                        "width": "col-span-3",
                        "height": "h-32",
                        "config": { "dataKey": "activity.steps", "color": "#fb923c" }
                    },
                    {
                        "id": "trend-hr",
                        "type": "trend",
                        "title": "Overnight heart rate",
                        "width": "col-span-6",
                        "height": "h-40",
                        "config": {
                            "dataKey": "sleep_session.hr_data",
                            "color": "#f87171",
                            "dataKeys": ["sleep_session.hr_data"],
                            "showPoints": false
                        }
                    },
                    {
                        "id": "trend-hrv",
                        "type": "trend",
                        "title": "Overnight HRV",
                        "width": "col-span-6",
                        "height": "h-40",
                        "config": {
                            "dataKey": "sleep_session.hrv_data",
                            "color": "#c084fc",
                            "dataKeys": ["sleep_session.hrv_data"],
                            "showPoints": false
                        }
                    },
                    {
                        "id": "trend-phases",
                        "type": "trend",
                        "title": "Sleep stages",
                        "width": "col-span-8",
                        "height": "h-40",
                        "config": {
                            "dataKey": "sleep_session.sleep_phase_5_min",
                            "color": "#8AB4F8",
                            "dataKeys": ["sleep_session.sleep_phase_5_min"]
                        }
                    },
                    {
                        "id": "sleep-table",
                        "type": "table",
                        "title": "Sleep details",
                        "width": "col-span-4",
                        "height": "h-40",
                        "config": {
                            "dataKey": "sleep_session.total_sleep_duration",
                            "color": "#8AB4F8",
                            "dataKeys": [
                                "sleep_session.start_time",
                                "sleep_session.end_time",
                                "sleep_session.latency",
                                "sleep_session.total_sleep_duration",
                                "sleep_session.deep_sleep_duration",
                                "sleep_session.rem_sleep_duration",
                                "sleep_session.light_sleep_duration",
                                "sleep_session.awake_time",
                                "sleep_session.average_heart_rate",
                                "sleep_session.average_hrv",
                                "sleep_session.lowest_heart_rate",
                                "sleep_session.average_breath",
                                "sleep_session.efficiency",
                                "sleep.average_spo2",
                                "sleep.breathing_disturbance_index"
                            ]
                        }
                    }
                ],
                "layout": [
                    { "i": "sleep-score", "x": 0, "y": 0, "w": 4, "h": 4, "moved": false, "static": false },
                    { "i": "readiness-score", "x": 4, "y": 0, "w": 4, "h": 4, "moved": false, "static": false },
                    { "i": "activity-score", "x": 8, "y": 0, "w": 4, "h": 4, "moved": false, "static": false },
                    { "i": "sleep-radar", "x": 0, "y": 4, "w": 4, "h": 4, "moved": false, "static": false },
                    { "i": "readiness-radar", "x": 4, "y": 4, "w": 4, "h": 4, "moved": false, "static": false },
                    { "i": "activity-radar", "x": 8, "y": 4, "w": 4, "h": 4, "moved": false, "static": false },
                    { "i": "metric-sleep", "x": 0, "y": 8, "w": 3, "h": 3, "moved": false, "static": false },
                    { "i": "metric-hrv", "x": 3, "y": 8, "w": 3, "h": 3, "moved": false, "static": false },
                    { "i": "metric-rhr", "x": 6, "y": 8, "w": 3, "h": 3, "moved": false, "static": false },
                    { "i": "metric-steps", "x": 9, "y": 8, "w": 3, "h": 3, "moved": false, "static": false },
                    { "i": "trend-hr", "x": 0, "y": 11, "w": 6, "h": 5, "moved": false, "static": false },
                    { "i": "trend-hrv", "x": 6, "y": 11, "w": 6, "h": 5, "moved": false, "static": false },
                    { "i": "trend-phases", "x": 0, "y": 16, "w": 8, "h": 5, "moved": false, "static": false },
                    { "i": "sleep-table", "x": 8, "y": 16, "w": 4, "h": 8, "moved": false, "static": false }
                ]
            },
            {
                "id": "trends",
                "name": "Trends",
                "widgets": [
                    {
                        "id": "trend-scores",
                        "type": "trend",
                        "title": "Scores (30 days)",
                        "width": "col-span-12",
                        "height": "h-40",
                        "config": {
                            "dataKey": "sleep.score",
                            "color": "#8AB4F8",
                            "dataKeys": ["sleep.score", "readiness.score", "activity.score"],
                            "dateRange": { "type": "relative", "value": 30, "unit": "days", "anchor": "selected_date" },
                            "showPoints": true
                        }
                    },
                    {
                        "id": "trend-hrv-daily",
                        "type": "trend",
                        "title": "Daily avg HRV (30 days)",
                        "width": "col-span-6",
                        "height": "h-40",
                        "config": {
                            "dataKey": "sleep_session.average_hrv",
                            "color": "#c084fc",
                            "dataKeys": ["sleep_session.average_hrv"],
                            "dateRange": { "type": "relative", "value": 30, "unit": "days", "anchor": "selected_date" },
                            "showPoints": true
                        }
                    },
                    {
                        "id": "trend-rhr-daily",
                        "type": "trend",
                        "title": "Resting HR (30 days)",
                        "width": "col-span-6",
                        "height": "h-40",
                        "config": {
                            "dataKey": "sleep_session.lowest_heart_rate",
                            "color": "#f87171",
                            "dataKeys": ["sleep_session.lowest_heart_rate"],
                            "dateRange": { "type": "relative", "value": 30, "unit": "days", "anchor": "selected_date" },
                            "showPoints": true
                        }
                    },
                    {
                        "id": "trend-steps",
                        "type": "trend",
                        "title": "Steps (30 days)",
                        "width": "col-span-6",
                        "height": "h-40",
                        "config": {
                            "dataKey": "activity.steps",
                            "color": "#fb923c",
                            "dataKeys": ["activity.steps"],
                            "dateRange": { "type": "relative", "value": 30, "unit": "days", "anchor": "selected_date" },
                            "showPoints": false
                        }
                    },
                    {
                        "id": "trend-sleep-dur",
                        "type": "trend",
                        "title": "Total sleep duration (30 days)",
                        "width": "col-span-6",
                        "height": "h-40",
                        "config": {
                            "dataKey": "sleep_session.total_sleep_duration",
                            "color": "#8AB4F8",
                            "dataKeys": ["sleep_session.total_sleep_duration"],
                            "dateRange": { "type": "relative", "value": 30, "unit": "days", "anchor": "selected_date" },
                            "showPoints": false
                        }
                    },
                    {
                        "id": "trend-resilience",
                        "type": "trend",
                        "title": "Resilience",
                        "width": "col-span-12",
                        "height": "h-40",
                        "config": {
                            "dataKey": "resilience.stress",
                            "color": "#8AB4F8",
                            "dataKeys": [
                                "resilience.sleep_recovery",
                                "resilience.daytime_recovery",
                                "resilience.stress"
                            ],
                            "dateRange": { "type": "relative", "value": 30, "unit": "days", "anchor": "selected_date" }
                        }
                    }
                ],
                "layout": [
                    { "i": "trend-scores", "x": 0, "y": 0, "w": 12, "h": 6, "moved": false, "static": false },
                    { "i": "trend-hrv-daily", "x": 0, "y": 6, "w": 6, "h": 5, "moved": false, "static": false },
                    { "i": "trend-rhr-daily", "x": 6, "y": 6, "w": 6, "h": 5, "moved": false, "static": false },
                    { "i": "trend-steps", "x": 0, "y": 11, "w": 6, "h": 5, "moved": false, "static": false },
                    { "i": "trend-sleep-dur", "x": 6, "y": 11, "w": 6, "h": 5, "moved": false, "static": false },
                    { "i": "trend-resilience", "x": 0, "y": 16, "w": 12, "h": 6, "moved": false, "static": false }
                ]
            }
        ],
        "activeDashboardId": "default"
    }
}
