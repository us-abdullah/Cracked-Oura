{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/hevy-insights", "destination": "/hevy-insights/index.html" },
    { "source": "/hevy-insights/", "destination": "/hevy-insights/index.html" },
    { "source": "/((?!hevy-insights/).*)", "destination": "/index.html" }
  ],
  "build": {
    "env": {
      "VITE_WEB_SNAPSHOT": "1"
    }
  }
}
